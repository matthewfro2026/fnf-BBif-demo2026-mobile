{
	"wrapping": {"maxLineLength": 400,"arrayWrap": {"defaultWrap": "keep"}},
	"lineEnds": {
		"anonFunctionCurly": {
		  "emptyCurly": "break",
		  "leftCurly": "after",
		  "rightCurly": "both"
		},
		"leftCurly": "both",
		"rightCurly": "both"
	  },

	  "emptyLines": {
		"importAndUsing": {
			"betweenImportsLevel": "firstLevelPackage",
			"betweenImports": 1,
			"beforeUsing": 1,
			"beforeType": 1
		},
		
		"enumAbstractEmptyLines": {
			"beginType": 0,
			"endType": 0,
			
			"betweenVars": 0,
			"afterVars": 1,
			
			"betweenFunctions": 1,
			"existingBetweenFields": "keep"
		},
		
		"maxAnywhereInFile": 1,
		
		"afterPackage": 1,
		
		"finalNewline": true
	},
	"sameLine": {
		"functionBody": "same",
		"ifBody": "same",
		"ifElse": "next",
		"elseBody": "same",
		"doWhile": "next",
		"tryBody": "next",
		"tryCatch": "next"
	},
	"indentation":{
		"trailingWhitespace": true
	}
}
